{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":prHourlyLimitNone",
    ":prConcurrentLimitNone"
  ],
  "packageRules": [
    {
      "matchCategories": [
        "python"
      ],
      "managerFilePatterns": [
        "/(^|/)pyproject\\.toml$/"
      ]
    },
    {
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "matchCurrentVersion": "!/^0/",
      "automerge": true,
      "labels": [
        "dependencies",
        "automerge"
      ]
    },
    {
      "groupName": "Pytest ecosystem",
      "matchPackageNames": ["pytest", "pytest-cov", "pytest-mock"]
    }
  ],
  "dependencyDashboard": true,
  "prCreation": "not-pending",
  "timezone": "Asia/Taipei",
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "managerFilePatterns": [
      "/(^|/)uv.lock$/",
      "/(^|/)pyproject\\.toml$/"
    ],
    "schedule": ["before 4am on monday"]
  }
}
