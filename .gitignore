## Minecraft Server Manager - .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
ENV/

# Build / packaging (Nuitka)
build/
dist/
*.dist/
*.build/
*.onefile-build/
*.onefile-dist/
.nuitka/
.nuitka-cache/
*.spec
*.manifest

# Test / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# OS
.DS_Store
Thumbs.db
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.lnk

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# Project runtime
config.json
/settings.json
*.log
logs/
temp/
tmp/
cache/

# Binaries (do not commit)
*.exe
*.msi
*.msix
*.msm
*.msp

# =====================
# Report directory
# =====================
report/*
!report/comprehensive_report.py
*.xml
